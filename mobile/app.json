{
  "expo": {
    "name": "Relay",
    "slug": "relay-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#DA7756"
    },
    "ios": {
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Relay uses speech recognition to transcribe voice prompts.",
        "NSMicrophoneUsageDescription": "Relay uses the microphone to capture voice prompts."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#DA7756"
      },
      "package": "io.github.bearyjd.relay",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-speech-recognition",
        {
          "androidSpeechServicePackages": [
            "com.google.android.tts",
            "com.google.android.as",
            "com.google.android.googlequicksearchbox",
            "com.google.android.voicesearch",
            "com.google.android.apps.googleassistant",
            "com.samsung.android.bixby.agent",
            "com.samsung.android.speech",
            "com.htc.sense.hsp",
            "com.nuance.android.vsuite.vsuiteapp",
            "com.iflytek.speechsuite"
          ]
        }
      ]
    ]
  }
}
